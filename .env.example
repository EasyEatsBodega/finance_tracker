# Provisioned automatically when you attach Vercel KV to the project.
# For local dev, run `vercel env pull .env.local` after linking the project.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Finnhub free API key — https://finnhub.io/register
FINNHUB_API_KEY=

# Random string. Vercel Cron sends `Authorization: Bearer $CRON_SECRET`
# on scheduled calls; /api/refresh requires it for cron-triggered runs.
CRON_SECRET=
